{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput --clear",
  "installCommand": "pip install -r requirements.txt",
  "framework": null,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/cron/expire-ads/",
      "schedule": "0 * * * *"
    },
    {
      "path": "/cron/notify-24h/",
      "schedule": "0 * * * *"
    },
    {
      "path": "/cron/notify-1h/",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/cron/promote-boosts/",
      "schedule": "0 */2 * * *"
    }
  ]
}
